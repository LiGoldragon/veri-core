# Sema Core — the primordial layer
# Every domain is a triad: { ordinal: Int => variant: String, structure: String }
# Ordinal is Solar (identity), variant is Lunar (name), structure is Saturnian (connection).
# Four prime generators: Polarity(2), Modality(3), Dignity(5), Archetype(7).
# Composites derive multiplicatively: Element=Pol², Sign=Elem×Mod, Decan=Sign×Mod.
# Connections derived from composition + ordinals — no stored morphisms.
# Full independence — no coexistence with samskara old stack.

# ═══════════════════════════════════════════════════════════════════════
# Meta-domains
# ═══════════════════════════════════════════════════════════════════════

:create Domain {
  ordinal: Int =>
  variant: String,
  structure: [String]
}

:create Astrality {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Structure {
  ordinal: Int =>
  variant: String,
  structure: String
}

# ═══════════════════════════════════════════════════════════════════════
# Prime generators
# ═══════════════════════════════════════════════════════════════════════

:create Polarity {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Modality {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Dignity {
  ordinal: Int =>
  variant: String,
  structure: String
}

:create Archetype {
  ordinal: Int =>
  variant: String,
  structure: String
}

# ═══════════════════════════════════════════════════════════════════════
