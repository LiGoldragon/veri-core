# ═══════════════════════════════════════════════════════════════════════
# Support relations
# ═══════════════════════════════════════════════════════════════════════

:create glyph {
  domain: String,
  variant: String =>
  codepoint: String
}

:create structure_field {
  owner: String,
  field: String =>
  structure: String,
  cardinality: String,
  ordinal: Int
}

:create measure_unit {
  measure: String =>
  unit_domain: String
}

# ═══════════════════════════════════════════════════════════════════════
# Schema relations (self-describing capnp schema)
# ═══════════════════════════════════════════════════════════════════════

:create schema_entry {
  schema: String,
  name: String =>
  structure: String,
  ordinal: Int
}

:create schema_field {
  schema: String,
  owner: String,
  name: String =>
  structure: String,
  target: String,
  ordinal: Int,
  cardinality: String
}

:create schema_variant {
  schema: String,
  owner: String,
  name: String =>
  ordinal: Int
}

:create schema_method {
  schema: String,
  interface: String,
  name: String =>
  ordinal: Int
}

:create schema_param {
  schema: String,
  interface: String,
  method: String,
  name: String =>
  direction: String,
  structure: String,
  target: String,
  ordinal: Int
}
