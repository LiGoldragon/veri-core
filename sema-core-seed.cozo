# Sema Core — Seeds
# Every domain: { ordinal: Int => variant: String, structure: String }
# Ordinal is Solar (key/identity), variant is Lunar (name), structure is Saturnian (connection).

# ═══════════════════════════════════════════════════════════════════════
# Meta-domains
# ═══════════════════════════════════════════════════════════════════════

?[ordinal, variant, structure] <- [
  [0, "dyad",    "Polarity"],
  [1, "triad",   "Modality"],
  [2, "pentad",  "Dignity"],
  [3, "heptad",  "Archetype"],
  [4, "dodecad", "Sign"],
]
:put Astrality { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0,  "Polarity",    ["dyad"]],
  [1,  "Modality",    ["triad"]],
  [2,  "Dignity",     ["pentad"]],
  [3,  "Archetype",   ["heptad"]],
  [4,  "Element",     ["Polarity", "Polarity"]],
  [5,  "Phase",       ["Modality"]],
  [6,  "Direction",   ["Polarity"]],
  [7,  "Sign",        ["Element", "Modality"]],
  [8,  "House",       ["Element", "Modality"]],
  [9,  "Dimension",   ["Element", "Modality"]],
  [10, "Measure",     ["Element", "Modality"]],
  [11, "Decan",       ["Sign", "Modality"]],
  [12, "Aspect",      ["Dignity"]],
  [13, "AspectNature", ["Dignity"]],
  [14, "Condition",   ["Element", "Polarity"]],
  [15, "Scalar",      ["Polarity", "Polarity"]],
  [16, "Cardinality", ["Polarity", "Polarity"]],
  [17, "TimeUnit",    ["Polarity", "Modality"]],
  [18, "PositionUnit", ["Polarity", "Polarity"]],
  [19, "CountUnit",   ["Modality"]],
  [20, "SizeUnit",    ["Modality"]],
  [21, "Astrality",   ["Dignity"]],
  [22, "Domain",      []],
  [23, "Structure",   []],
]
:put Domain { ordinal => variant, structure }

# ═══════════════════════════════════════════════════════════════════════
# Prime generators
# ═══════════════════════════════════════════════════════════════════════

?[ordinal, variant, structure] <- [
  [0, "solar", "none"],
  [1, "lunar", "none"],
]
:put Polarity { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0, "cardinal", "none"],
  [1, "fixed",    "none"],
  [2, "mutable",  "none"],
]
:put Modality { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0, "space", "none"],
  [1, "air",   "none"],
  [2, "fire",  "none"],
  [3, "water", "none"],
  [4, "earth", "none"],
]
:put Dignity { ordinal => variant, structure }

# Chaldean order: slowest orbit to fastest
?[ordinal, variant, structure] <- [
  [0, "saturn",  "none"],
  [1, "jupiter", "none"],
  [2, "mars",    "none"],
  [3, "sun",     "none"],
  [4, "venus",   "none"],
  [5, "mercury", "none"],
  [6, "moon",    "none"],
]
:put Archetype { ordinal => variant, structure }

# ═══════════════════════════════════════════════════════════════════════
# Composite domains — astrological
# ═══════════════════════════════════════════════════════════════════════

# Element = Polarity x Polarity (solar/solar=fire, lunar/solar=earth, solar/lunar=air, lunar/lunar=water)
?[ordinal, variant, structure] <- [
  [0, "fire",  "none"],
  [1, "earth", "none"],
  [2, "air",   "none"],
  [3, "water", "none"],
]
:put Element { ordinal => variant, structure }

# Sign = Element x Modality
# ordinal = element * 3 + modality (mixed-radix: element is the slow dimension)
# Actually: ordinal = modality * 4 + element? Let me think...
# Sign(12) = Element(4) x Modality(3). Mixed-radix: ordinal = element + 4 * modality
# @0 = fire+cardinal = aries, @1 = earth+cardinal = taurus, ...
# @4 = fire+fixed = leo, @5 = earth+fixed = virgo, ...
?[ordinal, variant, structure] <- [
  [0,  "aries",       "none"],
  [1,  "taurus",      "none"],
  [2,  "gemini",      "none"],
  [3,  "cancer",      "none"],
  [4,  "leo",         "none"],
  [5,  "virgo",       "none"],
  [6,  "libra",       "none"],
  [7,  "scorpio",     "none"],
  [8,  "sagittarius", "none"],
  [9,  "capricorn",   "none"],
  [10, "aquarius",    "none"],
  [11, "pisces",      "none"],
]
:put Sign { ordinal => variant, structure }

# House = Element x Modality (aligned with Sign)
?[ordinal, variant, structure] <- [
  [0,  "1st",  "none"],
  [1,  "2nd",  "none"],
  [2,  "3rd",  "none"],
  [3,  "4th",  "none"],
  [4,  "5th",  "none"],
  [5,  "6th",  "none"],
  [6,  "7th",  "none"],
  [7,  "8th",  "none"],
  [8,  "9th",  "none"],
  [9,  "10th", "none"],
  [10, "11th", "none"],
  [11, "12th", "none"],
]
:put House { ordinal => variant, structure }

# Dimension = Element x Modality (Young's geometry ordering)
?[ordinal, variant, structure] <- [
  [0,  "position",     "none"],
  [1,  "momentum",     "none"],
  [2,  "velocity",     "none"],
  [3,  "moment",       "none"],
  [4,  "inertia",      "none"],
  [5,  "mass_control", "none"],
  [6,  "acceleration", "none"],
  [7,  "force",        "none"],
  [8,  "control",      "none"],
  [9,  "energy",       "none"],
  [10, "power",        "none"],
  [11, "action",       "none"],
]
:put Dimension { ordinal => variant, structure }

# Measure = Element x Modality (aligned with Dimension)
?[ordinal, variant, structure] <- [
  [0,  "L",      "none"],
  [1,  "ML",     "none"],
  [2,  "L/T",    "none"],
  [3,  "ML/T",   "none"],
  [4,  "ML²",    "none"],
  [5,  "ML²/T",  "none"],
  [6,  "L/T²",   "none"],
  [7,  "ML/T²",  "none"],
  [8,  "L/T³",   "none"],
  [9,  "ML²/T²", "none"],
  [10, "ML/T³",  "none"],
  [11, "ML²/T³", "none"],
]
:put Measure { ordinal => variant, structure }

