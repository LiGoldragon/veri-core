# Aspect (Dignity-aligned)
?[ordinal, variant, structure] <- [
  [0, "conjunction", "none"],
  [1, "sextile",     "none"],
  [2, "trine",       "none"],
  [3, "square",      "none"],
  [4, "opposition",  "none"],
]
:put Aspect { ordinal => variant, structure }

# AspectNature (Dignity-aligned)
?[ordinal, variant, structure] <- [
  [0, "fusion",   "none"],
  [1, "flow",     "none"],
  [2, "harmony",  "none"],
  [3, "tension",  "none"],
  [4, "polarity", "none"],
]
:put AspectNature { ordinal => variant, structure }

# Condition = Element x Polarity
?[ordinal, variant, structure] <- [
  [0, "cazimi",      "none"],
  [1, "combustion",  "none"],
  [2, "direct",      "none"],
  [3, "occidental",  "none"],
  [4, "oriental",    "none"],
  [5, "retrograde",  "none"],
