  [8,  "gemini-3",      "none"],
  [9,  "cancer-1",      "none"],
  [10, "cancer-2",      "none"],
  [11, "cancer-3",      "none"],
  [12, "leo-1",         "none"],
  [13, "leo-2",         "none"],
  [14, "leo-3",         "none"],
  [15, "virgo-1",       "none"],
  [16, "virgo-2",       "none"],
  [17, "virgo-3",       "none"],
  [18, "libra-1",       "none"],
