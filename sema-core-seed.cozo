?[domain, variant, codepoint] <- [
  ["Archetype", "saturn",  "♄"],
  ["Archetype", "jupiter", "♃"],
  ["Archetype", "mars",    "♂"],
  ["Archetype", "sun",     "☉"],
  ["Archetype", "venus",   "♀"],
  ["Archetype", "mercury", "☿"],
  ["Archetype", "moon",    "☽"],
  ["Sign", "aries",       "♈"],
  ["Sign", "taurus",      "♉"],
  ["Sign", "gemini",      "♊"],
  ["Sign", "cancer",      "♋"],
  ["Sign", "leo",         "♌"],
  ["Sign", "virgo",       "♍"],
  ["Sign", "libra",       "♎"],
  ["Sign", "scorpio",     "♏"],
  ["Sign", "sagittarius", "♐"],
  ["Sign", "capricorn",   "♑"],
