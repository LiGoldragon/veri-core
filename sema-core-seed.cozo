# ═══════════════════════════════════════════════════════════════════════
# Aligned domains
# ═══════════════════════════════════════════════════════════════════════

# Phase (Modality-aligned)
?[ordinal, variant, structure] <- [
  [0, "becoming", "none"],
  [1, "manifest", "none"],
  [2, "retired",  "none"],
]
:put Phase { ordinal => variant, structure }

# Direction (Polarity-aligned)
?[ordinal, variant, structure] <- [
  [0, "request",  "none"],
  [1, "response", "none"],
]
:put Direction { ordinal => variant, structure }

# Scalar (Element-aligned)
?[ordinal, variant, structure] <- [
  [0, "domain", "none"],
  [1, "data",   "none"],
  [2, "bool",   "none"],
  [3, "int",    "none"],
]
:put Scalar { ordinal => variant, structure }

# Cardinality (Element-aligned)
?[ordinal, variant, structure] <- [
  [0, "one",      "none"],
  [1, "map",      "none"],
  [2, "many",     "none"],
  [3, "optional", "none"],
]
:put Cardinality { ordinal => variant, structure }

# ═══════════════════════════════════════════════════════════════════════
# Unit sub-domains
# ═══════════════════════════════════════════════════════════════════════

?[ordinal, variant, structure] <- [
  [0, "second",   "none"],
  [1, "minute",   "none"],
  [2, "hour",     "none"],
  [3, "day",      "none"],
  [4, "year",     "none"],
  [5, "epoch_ms", "none"],
]
:put TimeUnit { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0, "ordinal",     "none"],
  [1, "byte_offset", "none"],
  [2, "line",        "none"],
  [3, "index",       "none"],
]
:put PositionUnit { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0, "count",     "none"],
  [1, "row_count", "none"],
  [2, "arity",     "none"],
]
:put CountUnit { ordinal => variant, structure }

?[ordinal, variant, structure] <- [
  [0, "byte",     "none"],
  [1, "kilobyte", "none"],
  [2, "megabyte", "none"],
]
:put SizeUnit { ordinal => variant, structure }

?[measure, unit_domain] <- [
  ["L",      "PositionUnit"],
  ["L/T",    "TimeUnit"],
  ["L/T²",   "TimeUnit"],
  ["L/T³",   "TimeUnit"],
  ["ML",     "CountUnit"],
  ["ML/T",   "CountUnit"],
  ["ML/T²",  "CountUnit"],
  ["ML/T³",  "SizeUnit"],
  ["ML²",    "SizeUnit"],
  ["ML²/T",  "TimeUnit"],
  ["ML²/T²", "SizeUnit"],
  ["ML²/T³", "SizeUnit"],
]
:put measure_unit { measure => unit_domain }

# ═══════════════════════════════════════════════════════════════════════
