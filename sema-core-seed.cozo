# Sema Core — Domain Variant Seeds
# Ordinal alignment: variant order matches generator order.
# @0 in any 3-domain = cardinal quality. @1 = fixed. @2 = mutable.
# @0 in any 4-domain = fire quality. @1 = earth. @2 = air. @3 = water.
# @0 in any 5-domain = space quality. @1 = air. @2 = fire. @3 = water. @4 = earth.

# ═══════════════════════════════════════════════════════════════════════
# Phase & Dignity (primordial — no phase/dignity columns on themselves)
# ═══════════════════════════════════════════════════════════════════════

# Phase ordinal-aligned with Modality: @0=cardinal, @1=fixed, @2=mutable
?[name, glyph, in_world_hash, description] <- [
  ["becoming", "☽", false, "Staged, proposed — what is being considered"],
  ["manifest", "☉", true, "Current, active — what IS"],
  ["retired", "♄", false, "Archived, superseded — what WAS"],
]
:put Phase { name => glyph, in_world_hash, description }

# Dignity: the five elements as quality levels
?[name, rank, description] <- [
  ["space", 0, "Dwelling, full authority. Trust: eternal. Placement: domicile."],
  ["air", 1, "Insight, precision. Trust: proven. Placement: exaltation."],
  ["fire", 2, "Affinity, recognition. Trust: seen. Placement: triplicity."],
  ["water", 3, "Resonance, unfixed. Trust: uncertain. Placement: bound."],
  ["earth", 4, "Surface, bare contact. Trust: delusion. Placement: face."],
]
:put Dignity { name => rank, description }

# ═══════════════════════════════════════════════════════════════════════
# META — Domain registry, Functor
# ═══════════════════════════════════════════════════════════════════════

?[name, description, phase, dignity] <- [
  ["Phase", "Lifecycle (3, Modality-aligned): becoming/manifest/retired", "manifest", "space"],
  ["Dignity", "Quality of fitness (5 elements): space/air/fire/water/earth", "manifest", "space"],
  ["Domain", "Registry of all controlled vocabularies", "manifest", "space"],
  ["Functor", "How things map (3, Modality-aligned): bijective/deterministic/tradition_dependent", "manifest", "space"],
  ["Element", "Four elements = Polarity² (4): fire/earth/air/water", "manifest", "space"],
  ["Modality", "3rd prime generator (3): cardinal/fixed/mutable", "manifest", "space"],
  ["Sign", "Twelve zodiacal signs (12 = 2²×3)", "manifest", "space"],
  ["Archetype", "4th prime generator (7): sun/moon/mars/saturn/mercury/jupiter/venus", "manifest", "space"],
  ["Measure", "Young Geometry of Meaning — 12 measure formulae", "manifest", "space"],
  ["Dimension", "Twelve physics dimensions from Young", "manifest", "space"],
  ["House", "Twelve topical houses — areas of life experience", "manifest", "space"],
  ["Aspect", "Geometric relationships (5, Dignity-aligned)", "manifest", "space"],
  ["AspectNature", "Qualitative nature of aspects (5, Dignity-aligned)", "manifest", "space"],
  ["Decan", "Thirty-six 10-degree divisions (36 = 2²×3²)", "manifest", "space"],
  ["Rulership", "Archetype-Sign dignity assignments", "manifest", "space"],
  ["Polarity", "1st prime generator (2): diurnal/nocturnal", "manifest", "space"],
  ["Condition", "Planetary conditions (8 = 2³)", "manifest", "space"],
  ["Type", "Structural form of a type (6 = 2×3)", "manifest", "space"],
  ["Scalar", "Leaf scalar (4, Element-aligned): domain/data/bool/int", "manifest", "space"],
  ["Cardinality", "Field multiplicity (4, Element-aligned): one/map/many/optional", "manifest", "space"],
  ["Direction", "Data flow (2, Polarity-aligned): request/response", "manifest", "space"],
  ["Name", "Universal label registry — all context-specific variant names", "manifest", "space"],
  ["TimeUnit", "Unit of time measurement", "manifest", "space"],
  ["PositionUnit", "Unit of positional measurement", "manifest", "space"],
  ["CountUnit", "Unit of counting", "manifest", "space"],
  ["SizeUnit", "Unit of data size", "manifest", "space"],
]
:put Domain { name => description, phase, dignity }

# Functor ordinal-aligned with Modality: @0=cardinal, @1=fixed, @2=mutable
?[name, description, phase, dignity] <- [
  ["bijective", "One-to-one and onto — reversible", "manifest", "space"],
  ["deterministic", "Exactly one output for each input", "manifest", "space"],
  ["tradition_dependent", "Mapping varies by tradition or context", "manifest", "space"],
]
:put Functor { name => description, phase, dignity }

